echo "🎨 Running lint-staged on changed files..."

npx lint-staged

if [ $? -eq 0 ]; then
  echo "✅ Code formatting and linting passed!"
else
  echo "❌ Lint-staged failed! Please fix the issues above."
  exit 1
fi

echo "Dùng depcruise để kiểm tra DDD"

npm run ddd:check

echo "Dùng depcruise để tạo sơ đồ"
npm run ddd:docs

git add docs

echo "Dùng barrelsby để cập nhật index.ts"
npm run generate-barrels

git add src/index.ts

echo "Chạy Test Coverage"
npm run test:cov
